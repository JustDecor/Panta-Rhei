role-description-shiva = "Hsssss!"

role-description-pun-pun = "Ook!"

job-description-boxer = Пробийте собі шлях до вершини! Киньте виклик голові персоналу і потрапте в бриг, коли переможете. Наразі доступно на Core та Convex.

job-description-zookeeper = Влаштуйте радісне шоу з милими тваринами та космічними коропами для всього екіпажу. Наразі доступно на Oasis
