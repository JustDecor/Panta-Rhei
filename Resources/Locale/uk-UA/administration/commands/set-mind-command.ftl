cmd-setmind-desc = Переносить розум до вказаної сутності. Сутність повинна мати {$requiredComponent}. За замовчуванням це примусово повертає розуми, які зараз відвідують інші сутності (тобто повертає привида до їхнього основного тіла).

cmd-setmind-help = Використання: {$command} <entityUid> <ім'я користувача> [unvisit]

cmd-setmind-command-target-has-no-content-data-message = Цільовий гравець не має даних контенту (що за?)

cmd-setmind-command-target-has-no-mind-message = Цільова сутність не має розуму (забули зробити свідомою?)
